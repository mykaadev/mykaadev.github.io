{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Jekyll",
      "type": "shell",
      "command": "bundle exec jekyll serve --host localhost --port 4000",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "New Article",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/new-article.ps1",
        "${input:articleTitle}"
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "articleTitle",
      "type": "promptString",
      "description": "Article title"
    }
  ]
}
